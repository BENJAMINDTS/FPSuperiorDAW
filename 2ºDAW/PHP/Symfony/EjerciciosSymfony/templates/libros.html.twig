{% extends 'base.html.twig' %}

{% block title %}Listado de libros{% endblock %}

{% block body %}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <h1 style="margin-bottom:0;">Listado de libros</h1>
        <a href="/libro/insertar" style="
            background: linear-gradient(135deg, #a78bfa, #38bdf8);
            color: #fff;
            text-decoration: none;
            padding: 0.5rem 1.2rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.875rem;
        ">+ Insertar libro</a>
    </div>

    <div style="display:flex; flex-direction:column; gap:0.6rem;">
        {% for libro in libros %}
            <div style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 12px;
                padding: 0.85rem 1.25rem;
                transition: border-color 0.2s;
            ">
                <div>
                    <span style="font-weight:700; color:#fff;">{{ libro.titulo }}</span>
                    <span style="color:rgba(255,255,255,0.45); margin:0 0.5rem;">·</span>
                    <span style="color:rgba(255,255,255,0.6); font-size:0.9rem;">{{ libro.autor }}</span>
                    <span style="color:rgba(255,255,255,0.45); margin:0 0.5rem;">·</span>
                    <span style="color:#a78bfa; font-weight:600;">{{ libro.precio }}€</span>
                </div>
                <div style="display:flex; gap:0.5rem;">
                    <a href="/libro/{{ libro.id }}" style="
                        background: rgba(56,189,248,0.12);
                        border: 1px solid rgba(56,189,248,0.3);
                        color: #38bdf8;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                        transition: all 0.2s;
                    ">Ver</a>
                    <a href="/libro/{{ libro.id }}/actualizar" style="
                        background: rgba(167,139,250,0.12);
                        border: 1px solid rgba(167,139,250,0.3);
                        color: #a78bfa;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                        transition: all 0.2s;
                    ">Editar</a>
                    <a href="/libro/{{ libro.id }}/eliminar" style="
                        background: rgba(248,113,113,0.12);
                        border: 1px solid rgba(248,113,113,0.3);
                        color: #f87171;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                        transition: all 0.2s;
                    ">Eliminar</a>
                </div>
            </div>
        {% else %}
            <div style="
                text-align:center;
                padding: 2rem;
                color: rgba(255,255,255,0.3);
                border: 1px dashed rgba(255,255,255,0.1);
                border-radius: 12px;
            ">No hay libros en la base de datos.</div>
        {% endfor %}
    </div>
{% endblock %}
