{% extends 'base.html.twig' %}

{% block title %}{{ titulo }}{% endblock %}

{% block stylesheets %}
<style>
    /* Etiquetas */
    .field label {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #fb923c;
        margin-bottom: 0.4rem;
    }

    /* Inputs */
    .field input {
        width: 100%;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        padding: 0.7rem 1rem;
        color: #fff;
        font-size: 1rem;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }

    .field input:focus {
        border-color: #fb923c;
        box-shadow: 0 0 0 3px rgba(251,146,60,0.15);
    }

    /* Errores de validación */
    .field ul {
        list-style: none;
        margin-top: 0.4rem;
        gap: 0;
    }

    .field ul li {
        background: rgba(248,113,113,0.1);
        border: 1px solid rgba(248,113,113,0.3);
        border-radius: 8px;
        padding: 0.35rem 0.75rem;
        color: #f87171;
        font-size: 0.82rem;
        font-weight: 500;
        margin-top: 0.3rem;
        transform: none;
    }

    .field ul li:hover {
        background: rgba(248,113,113,0.1);
        border-color: rgba(248,113,113,0.3);
        transform: none;
    }

    /* Botón submit */
    .field button[type="submit"] {
        width: 100%;
        background: linear-gradient(135deg, #fb923c, #fbbf24);
        color: #0d0d14;
        border: none;
        border-radius: 10px;
        padding: 0.8rem 1.5rem;
        font-size: 1rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

    .field button[type="submit"]:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
</style>
{% endblock %}

{% block body %}
    <h1>{{ titulo }}</h1>

    {% if modo == 'editar' %}
        <p style="color:rgba(255,255,255,0.4); font-size:0.875rem; margin-bottom:1.5rem; margin-top:-0.75rem;">
            Editando: <strong style="color:rgba(255,255,255,0.7);">{{ pelicula.titulo }}</strong>
            &nbsp;·&nbsp; ID #{{ pelicula.id }}
        </p>
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'style': 'display:flex; flex-direction:column; gap:1.25rem;'}}) }}

        <div class="field">
            {{ form_label(form.titulo) }}
            {{ form_widget(form.titulo) }}
            {{ form_errors(form.titulo) }}
        </div>

        <div class="field">
            {{ form_label(form.director) }}
            {{ form_widget(form.director) }}
            {{ form_errors(form.director) }}
        </div>

        <div class="field">
            {{ form_label(form.anio) }}
            {{ form_widget(form.anio) }}
            {{ form_errors(form.anio) }}
        </div>

        <div class="field" style="margin-top:0.5rem;">
            {{ form_widget(form.guardar) }}
        </div>

    {{ form_end(form) }}

    <a href="/peliculas" style="
        display: inline-block;
        margin-top: 1rem;
        color: rgba(255,255,255,0.35);
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.2s;
    ">← Cancelar y volver al listado</a>

{% endblock %}
