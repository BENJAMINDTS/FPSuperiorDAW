{% extends 'base.html.twig' %}

{% block title %}Listado de películas{% endblock %}

{% block body %}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <h1 style="margin-bottom:0;">Películas</h1>
        <a href="/pelicula/insertar" style="
            background: linear-gradient(135deg, #fb923c, #fbbf24);
            color: #0d0d14;
            text-decoration: none;
            padding: 0.5rem 1.2rem;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.875rem;
        ">+ Insertar película</a>
    </div>

    <div style="display:flex; flex-direction:column; gap:0.6rem;">
        {% for pelicula in peliculas %}
            <div style="
                display: flex;
                align-items: center;
                justify-content: space-between;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 12px;
                padding: 0.85rem 1.25rem;
                transition: border-color 0.2s;
            ">
                <div>
                    <span style="font-weight:700; color:#fff;">{{ pelicula.titulo }}</span>
                    <span style="color:rgba(255,255,255,0.4); margin:0 0.5rem;">·</span>
                    <span style="color:rgba(255,255,255,0.55); font-size:0.9rem;">{{ pelicula.director }}</span>
                    <span style="color:rgba(255,255,255,0.4); margin:0 0.5rem;">·</span>
                    <span style="color:#fb923c; font-weight:600;">{{ pelicula.anio }}</span>
                </div>
                <div style="display:flex; gap:0.5rem;">
                    <a href="/pelicula/{{ pelicula.id }}" style="
                        background: rgba(251,191,36,0.12);
                        border: 1px solid rgba(251,191,36,0.35);
                        color: #fbbf24;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                    ">Ver</a>
                    <a href="/pelicula/{{ pelicula.id }}/editar" style="
                        background: rgba(251,146,60,0.12);
                        border: 1px solid rgba(251,146,60,0.35);
                        color: #fb923c;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                    ">Editar</a>
                    <a href="/pelicula/{{ pelicula.id }}/eliminar" style="
                        background: rgba(248,113,113,0.12);
                        border: 1px solid rgba(248,113,113,0.35);
                        color: #f87171;
                        text-decoration: none;
                        padding: 0.35rem 0.85rem;
                        border-radius: 8px;
                        font-size: 0.8rem;
                        font-weight: 600;
                    ">Eliminar</a>
                </div>
            </div>
        {% else %}
            <div style="
                text-align:center;
                padding: 2.5rem;
                color: rgba(255,255,255,0.25);
                border: 1px dashed rgba(255,255,255,0.1);
                border-radius: 12px;
                font-size: 1rem;
            ">
                No hay películas en la base de datos.<br>
                <a href="/pelicula/insertar" style="color:#fb923c; text-decoration:none; font-weight:600; margin-top:0.5rem; display:inline-block;">Insertar la primera</a>
            </div>
        {% endfor %}
    </div>
{% endblock %}
